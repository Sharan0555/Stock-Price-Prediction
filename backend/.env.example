#
# Backend-only env file example.
# If you're using Docker Compose from the repo root, prefer editing the root `.env`.
#

# Secrets
JWT_SECRET_KEY=change-me-use-a-long-random-string

# Backend CORS (JSON array of allowed origins)
BACKEND_CORS_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:3000","http://127.0.0.1:3000","http://localhost:80","http://127.0.0.1:80","https://your-vercel-app.vercel.app"]

# Data stores (for local dev outside Docker, use localhost; for Docker Compose, use service hostnames)
POSTGRES_DSN=postgresql+psycopg2://postgres:postgres@postgres:5432/stocks
MONGO_DSN=mongodb://mongo:27017/stocks
REDIS_URL=redis://redis:6379/0

# Market data providers
FINNHUB_API_KEY=your_finnhub_key
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key
ALPHAVANTAGE_INR_SUFFIX=.BSE

# Anthropic (for /api/chat proxy)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Feature flags
LOCAL_DATA_ONLY=0

# Google OAuth (optional; used by /api/v1/auth/google)
GOOGLE_CLIENT_ID=your_google_client_id
